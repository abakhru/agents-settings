# Discord Webhook Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to config/discord.env and fill in your webhook URLs.
# config/discord.env is gitignored — never commit real webhook URLs.
#
# How to create a webhook:
#   Discord Server → channel gear icon → Integrations → Webhooks → New Webhook
#   Copy the Webhook URL and paste it below.
# ──────────────────────────────────────────────────────────────────────────────

# Primary channel — general agent activity, task completions, handoffs
DISCORD_WEBHOOK_UPDATES=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Alerts channel — failures, security findings, blocked tasks (optional)
# Leave empty to fall back to DISCORD_WEBHOOK_UPDATES
DISCORD_WEBHOOK_ALERTS=

# Your name / handle shown as the sender label in messages
DISCORD_USERNAME="amit-ai-team"

# Avatar URL shown next to messages (optional — leave empty for default)
DISCORD_AVATAR_URL=
