# Discord Webhook Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to config/discord.env and fill in your webhook URLs.
# config/discord.env is gitignored — never commit real webhook URLs.
#
# How to create a webhook:
#   Discord Server → channel gear icon → Integrations → Webhooks → New Webhook
#   Copy the Webhook URL and paste it below.
# ──────────────────────────────────────────────────────────────────────────────

# Bot identity
DISCORD_USERNAME="amit-ai-team"
DISCORD_AVATAR_URL=

# ── Activity channels ──────────────────────────────────────────────────────────
# General task completions, session handoffs (fallback for any unrouted message)
DISCORD_WEBHOOK_UPDATES=

# Failures, blocked tasks, security findings, CI errors
DISCORD_WEBHOOK_ALERTS=

# ── Specialist channels ────────────────────────────────────────────────────────
DISCORD_WEBHOOK_PM=
DISCORD_WEBHOOK_DESIGN=
DISCORD_WEBHOOK_EXPLORATION=
DISCORD_WEBHOOK_ENGINEERING=
DISCORD_WEBHOOK_QA_STRATEGY=
DISCORD_WEBHOOK_QA_IMPLEMENTATION=
DISCORD_WEBHOOK_SECURITY=
DISCORD_WEBHOOK_PERFORMANCE=

# ── Process channels ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_DECISIONS=
DISCORD_WEBHOOK_CICD=
